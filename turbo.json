{
    "$schema": "https://turbo.build/schema.json",
    "globalDependencies": ["tsconfig.json"],
    "pipeline": {
      "build": {
        "dependsOn": ["^build"],
        "outputs": ["dist/**", "lib/**"]
      },
      "start": {
        "dependsOn": ["^build"],
        "outputs": []
      },
      "clean": {
        "cache": false,
        "outputs": []
      },
      "lint": {
        "outputs": []
      }
    }
  }