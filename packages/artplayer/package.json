{
	"license": "MIT",
	"name": "@artplayer/player",
	"version": "5.1.12",
	"publishConfig": {
		"access": "public"
	},
	"sideEffects": false,
	"exports": {
		"./package.json": "./package.json",
		"./artplayer.css": "./dist/artplayer.css",
		".": {
			"types": "./dist/index.d.ts",
			"module": "./dist/index.js",
			"import": "./dist/index.mjs",
			"default": "./dist/index.js"
		}
	},
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": ["dist"],
	"homepage": "https://artplayer.org",
	"browserslist": "last 1 Chrome version",
	"description": "ArtPlayer.js is a modern and full featured HTML5 video player",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/divyam234/ArtPlayer"
	},
	"bugs": {
		"url": "https://github.com/divyam234/ArtPlayer/issues"
	},
	"keywords": ["html5", "video", "player"],
	"scripts": {
		"build": "tsup",
		"publish": "pnpm publish --access public --no-git-checks"
	},
	"devDependencies": {
		"esbuild-plugin-less": "^1.3.10",
		"svgo": "^3.3.2",
		"tsup": "^8.3.0",
		"option-validator": "^2.0.6"
	}
}
